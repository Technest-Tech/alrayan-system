APP_NAME="Alrayan Academy API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://api.alrayan-academy.com
APP_VERSION=0.1.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_LEVEL=warning

# ── Database ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=alrayan_prod
DB_USERNAME=alrayan
DB_PASSWORD=

# ── Sessions & Cache ─────────────────────────────────────────
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.alrayan-academy.com

CACHE_STORE=file
QUEUE_CONNECTION=database

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://alrayan-academy.com,https://www.alrayan-academy.com,https://staging.alrayan-academy.com

# ── Sanctum ──────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=alrayan-academy.com,www.alrayan-academy.com,staging.alrayan-academy.com

# ── Mail (Resend) ─────────────────────────────────────────────
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS="info@alrayan-academy.com"
MAIL_FROM_NAME="Alrayan Academy"

ADMIN_NOTIFICATION_EMAIL=info@alrayan-academy.com

# ── Next.js ISR revalidation ──────────────────────────────────
NEXT_REVALIDATE_URL=https://alrayan-academy.com/api/revalidate
NEXT_REVALIDATE_SECRET=

# ── hCaptcha (Sprint 4) ───────────────────────────────────────
HCAPTCHA_SECRET=

# ── Sentry ────────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=

# ── Wasender (WhatsApp) ───────────────────────────────────────
WASSENDER_ENABLED=false
WASSENDER_API_KEY=

# ── AWS / Backblaze B2 (Sprint 7 backups) ─────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=

# ── XPay (Online Payments) ────────────────────────────────────
XPAY_ENABLED=false
